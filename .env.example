# Root env for `docker compose`. Copy to .env and adjust. Component-level
# overrides live in backend/.env and frontend/.env.

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=agentmail
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=agent_mail

# ─── Mail / routing ─────────────────────────────────────────────────────────
# Base domain for shared subdomain-key mailboxes: anything@<KEY>.<EMAIL_DOMAIN>
EMAIL_DOMAIN=example.com
# Host a custom domain's MX must point to in order to verify.
MAIL_HOST=mail.example.com
MAIL_SERVER_IP=203.0.113.10
POLL_INTERVAL=10

# ─── Frontend ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080

# ─── Security (see docs/security.md) ────────────────────────────────────────
CORS_ALLOW_ORIGINS=*
ADMIN_API_TOKEN=
RATE_LIMIT_PER_MINUTE=120
EMAIL_RETENTION_DAYS=0
