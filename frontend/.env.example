# Base URL of the Agent Mail backend API.
VITE_API_URL=http://localhost:8080

# Base domain shown for subdomain-key addresses: anything@<key>.<EMAIL_DOMAIN>
VITE_EMAIL_DOMAIN=example.com

# Host that custom domains must point their MX record to (shown in verify UI).
# Defaults to mail.<VITE_EMAIL_DOMAIN> if left unset.
VITE_MAIL_HOST=mail.example.com

# Optional: comma-separated allowlist of hostnames for the Vite dev server.
# Leave empty to allow any host in local dev.
VITE_ALLOWED_HOSTS=
