# Base URL of the Agent Mail backend (managed or self-hosted).
AGENT_MAIL_API_URL=http://localhost:8080

# Base domain for subdomain-key addresses: anything@<key>.<EMAIL_DOMAIN>
AGENT_MAIL_EMAIL_DOMAIN=example.com

# Optional: set only if the backend requires an admin token (X-Admin-Token).
AGENT_MAIL_ADMIN_TOKEN=
