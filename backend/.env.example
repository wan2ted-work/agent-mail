# ─── Database ─────────────────────────────────────────────────────────────
# Async SQLAlchemy URL. Use a strong, unique password and never commit the real one.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_mail

# ─── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ─── Maildir ──────────────────────────────────────────────────────────────
# Directory Postfix delivers new mail into; the worker polls this path.
MAILDIR_PATH=/root/Maildir/new
# Base domain for subdomain-key mailboxes: anything@<KEY>.<EMAIL_DOMAIN>
EMAIL_DOMAIN=example.com

# ─── Custom domains ───────────────────────────────────────────────────────
# Host that a custom domain's MX record must point to in order to verify.
MAIL_HOST=mail.example.com
# Mail server public IP (fallback A-record check during MX verification).
MAIL_SERVER_IP=203.0.113.10

# ─── Worker ───────────────────────────────────────────────────────────────
# Seconds between Maildir polls.
POLL_INTERVAL=10

# ─── Security (see docs/security.md) ──────────────────────────────────────
# Comma-separated list of allowed CORS origins. Use explicit origins in
# production instead of "*". Example: https://app.example.com,https://example.com
CORS_ALLOW_ORIGINS=*
# Optional shared admin token. When set, mutating/admin endpoints require the
# header  X-Admin-Token: <value>  in addition to the instance secret. Leave
# empty to disable (open mode, suitable only for local/dev).
ADMIN_API_TOKEN=
# Requests per minute per client IP (0 = disabled).
RATE_LIMIT_PER_MINUTE=120
# Delete stored emails older than this many days (0 = keep forever).
EMAIL_RETENTION_DAYS=0
